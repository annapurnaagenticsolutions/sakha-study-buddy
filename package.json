{
  "dependencies": {
    "@mlc-ai/web-llm": "^0.2.84",
    "@xenova/transformers": "^2.17.2",
    "assemblyscript": "^0.28.19",
    "mermaid": "^11.15.0",
    "peerjs": "^1.5.5",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.1"
  },
  "scripts": {
    "build": "esbuild ./src/app-static.js --bundle --format=esm --splitting --outdir=dist --entry-names=main --chunk-names=chunks/[name]-[hash] --minify && copy /Y src\\wasm\\physics.wasm dist\\physics.wasm >NUL",
    "check": "npm run build && npm run size-check",
    "size-check": "node scripts/check-bundle-size.js",
    "content-check": "node scripts/check-content-quality.js"
  }
}
